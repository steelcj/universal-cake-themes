#!/usr/bin/env python3
"""
generate-theme-skeleton.py

UniversalCake Theme Skeleton Generator

Creates a theme directory structure from a YAML description file.

OS agnostic.
Standard library only.
"""

import sys
import os
from pathlib import Path
import argparse

try:
    import yaml
except ImportError:
    print("Error: PyYAML is required.")
    print("Install with: pip install pyyaml")
    sys.exit(1)


def load_yaml(yaml_path: Path) -> dict:
    with yaml_path.open("r", encoding="utf-8") as f:
        return yaml.safe_load(f)


def create_file(path: Path):
    if not path.exists():
        path.touch()
        print(f"Created file: {path}")
    else:
        print(f"Skipped existing file: {path}")


def create_directory(path: Path):
    if not path.exists():
        path.mkdir(parents=True, exist_ok=True)
        print(f"Created directory: {path}")
    else:
        print(f"Skipped existing directory: {path}")


def generate_structure(base_path: Path, structure: list):
    for item in structure:
        item_path = base_path / item

        # Normalize forward slashes for cross-platform support
        item_path = Path(str(item_path))

        if item.endswith("/"):
            create_directory(item_path)
        elif "." in item_path.name:
            create_directory(item_path.parent)
            create_file(item_path)
        else:
            create_directory(item_path)


def main():
    parser = argparse.ArgumentParser(
        description="Generate a UniversalCake theme skeleton from YAML definition."
    )

    parser.add_argument(
        "yaml_file",
        type=str,
        help="Path to YAML definition file."
    )

    parser.add_argument(
        "--themes-dir",
        type=str,
        default="themes",
        help="Base themes directory (default: themes)"
    )

    args = parser.parse_args()

    yaml_path = Path(args.yaml_file).resolve()

    if not yaml_path.exists():
        print(f"YAML file not found: {yaml_path}")
        sys.exit(1)

    config = load_yaml(yaml_path)

    theme_name = config.get("theme", {}).get("name")

    if not theme_name:
        print("Error: theme.name is required in YAML.")
        sys.exit(1)

    structure = config.get("structure")

    if not structure:
        print("Error: structure section is required in YAML.")
        sys.exit(1)

    base_dir = Path(args.themes_dir).resolve()
    theme_dir = base_dir / theme_name

    create_directory(theme_dir)
    generate_structure(theme_dir, structure)

    print("\nTheme skeleton generation complete.")


if __name__ == "__main__":
    main()
